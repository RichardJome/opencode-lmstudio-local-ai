{
  "$schema": "https://opencode.ai/config.json",

  "provider": {
    "lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio (Local)",
      "options": {
        "baseURL": "http://localhost:1234/v1"
      },
      "models": {
        "qwen3.5:9b": {
          "name": "Qwen3.5 9B (Local)"
        },
        "qwen3:14b": {
          "name": "Qwen3 14B"
        }
      }
    }
  },

  "model": "qwen3.5:9b",

  "permission": {
    "bash": "allow",
    "read": "allow",
    "write": "allow",
    "edit": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "question": "allow",
    "todoread": "allow",
    "todowrite": "allow",
    "skill": "allow",
    "patch": "allow",
    "lsp": "allow"
  },

  "experimental": {
    "lsp": true
  },

  "mcp": {
    "web-search": {
      "type": "local",
      "command": ["npx", "-y", "@oevortex/ddg_search@latest"]
    },
    "filesystem": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-filesystem@latest", "./project_files"]
    },
    "memory": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-memory@latest"]
    },
        "github": {
      "type": "remote",
      "url": "https://api.github.com",
      "headers": { "Authorization": "Bearer YOUR_GITHUB_TOKEN" }
        }
  }
}
